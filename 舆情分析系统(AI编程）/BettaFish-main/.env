MINDSPIDER_BASE_URL=https://api.siliconflow.cn/v1
MINDSPIDER_MODEL_NAME=Qwen/Qwen3.5-397B-A17B

# 论坛主持人（跳过ForumEngine，但跨引擎修复会用到这个配置）
FORUM_HOST_API_KEY=sk-09b3476044b84cde8d55c355c55af147
FORUM_HOST_BASE_URL=https://api.deepseek.com
FORUM_HOST_MODEL_NAME=deepseek-chat

# SQL Keyword Optimizer
KEYWORD_OPTIMIZER_API_KEY=sk-09b3476044b84cde8d55c355c55af147
KEYWORD_OPTIMIZER_BASE_URL=https://api.deepseek.com
